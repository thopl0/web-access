# Copy to .env and adjust as needed.
# Ports match docker-compose.yml (remapped off the defaults to avoid collisions).
DATABASE_URL=postgres://webaccess:webaccess@localhost:5544/webaccess
REDIS_URL=redis://localhost:6399
API_PORT=3001
# Public base URL of the ingest API (used by the embed script's build/config).
INGEST_BASE_URL=http://localhost:3001
