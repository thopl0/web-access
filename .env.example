# Copy to .env and adjust as needed.
# Ports match docker-compose.yml (remapped off the defaults to avoid collisions).
DATABASE_URL=postgres://webaccess:webaccess@localhost:5544/webaccess
REDIS_URL=redis://localhost:6399

# Worker render tuning (optional).
# NAV_TIMEOUT_MS=30000
# WORKER_CONCURRENCY=2
# Scheduled monitoring: how often the worker re-crawls every verified, non-paused site (ms).
# Default 24h; set to 0 to disable scheduled re-crawls.
# MONITOR_INTERVAL_MS=86400000
# Max Postgres connections per process pool (default 10).
# PG_POOL_MAX=10

# Email alerts (verification success, new-critical, weekly digest). Sent via the Resend HTTP API.
# When BOTH are set, emails are sent; otherwise the email layer no-ops (logs only).
# RESEND_API_KEY=
# EMAIL_FROM=Accessibility <alerts@yourdomain.com>
# Weekly digest cadence (ms, default 7d). Set to 0 to disable digests.
# DIGEST_INTERVAL_MS=604800000

# The Next app (UI + /v1 API) listens on PORT (default 3000); set it when running `next start`.
# PORT=3000

# Object storage for screenshots + element evidence (lib/server/storage.ts). The bytes live OUTSIDE
# Postgres; only a small object key is kept in the DB. Driver is auto-selected when STORAGE_DRIVER is
# unset: Cloudflare R2 if its creds are present, else the local filesystem.
#
# Dev (default): local disk — no cloud bucket needed.
# STORAGE_DRIVER=local
# STORAGE_DIR=.data/storage
#
# Prod: Cloudflare R2 (S3-compatible). Create a bucket + an R2 API token (S3 credentials). The driver
# auto-selects 'r2' once R2_BUCKET_NAME is set. R2_API_ENDPOINT is the bucket's S3 endpoint (Cloudflare
# usually shows it WITH the bucket path); if unset it's built from R2_ACCOUNT_ID + R2_BUCKET_NAME.
# R2_ACCESS_KEY is the secret access key. R2_PUBLIC_URL is intentionally unused — images are streamed
# through the access-controlled /api routes, so keep the bucket PRIVATE.
# R2_API_ENDPOINT=https://<account>.r2.cloudflarestorage.com/web-access
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=web-access
# R2_ACCESS_KEY_ID=
# R2_ACCESS_KEY=
# R2_PUBLIC_URL=

# Auth.js — required secret used to sign session JWTs. Generate with:
#   openssl rand -base64 32
AUTH_SECRET=replace-me

# Optional: canonical public origin baked into the embed <script> snippets shown
# in the dashboard. Falls back to the incoming request's origin when unset.
# APP_ORIGIN=http://localhost:3000

# Optional: Google OAuth ("Continue with Google"). Enabled only when BOTH are set.
# Create a client at https://console.cloud.google.com/apis/credentials with:
#   Authorized JavaScript origin:  http://localhost:3000   (and your prod origin)
#   Authorized redirect URI:       http://localhost:3000/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# GLM (Zhipu AI) — powers the Tier-3 AI judge (alt-text fidelity / decorative-image
# misclassification). When unset, the AI analyzer no-ops and only the deterministic
# tiers (axe + geometry + contrast) run. A GLM Coding Plan key works here.
GLM_API_KEY=
# Anthropic-compatible base URL (the SDK appends /v1/messages). Coding-plan keys are
# served here, NOT at the OpenAI-style /paas/v4 endpoint.
#   International: https://api.z.ai/api/anthropic   (default)
#   Mainland:      https://open.bigmodel.cn/api/anthropic
# GLM_BASE_URL=https://api.z.ai/api/anthropic
# GLM_TEXT_MODEL=glm-4.6
# GLM_MAX_TOKENS=1024
# GLM_TIMEOUT_MS=30000
# NOTE: the Tier-3 judge is TEXT-ONLY (alt-text quality from alt string + filename + DOM context).
# GLM's coding-plan endpoint does not deliver images to the model, so there is no vision check yet.
# GLM_VISION_MODEL is unused until a vision-capable provider is wired up.
