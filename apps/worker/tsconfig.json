{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // DOM is needed because we import the analyzers' source, which contains browser-side
    // page.evaluate() snippets that reference DOM globals.
    "lib": ["ES2023", "DOM"],
    "types": ["node"],
    "noEmit": true,
    "declaration": false
  },
  "include": ["src"]
}
