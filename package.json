{
  "name": "web-access",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "predev": "pnpm build:embed",
    "dev": "next dev",
    "prebuild": "pnpm build:embed",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build:embed": "tsup --config embed/tsup.config.ts",
    "dev:worker": "tsx watch worker/index.ts",
    "start:worker": "tsx worker/index.ts",
    "dev:visit": "tsx worker/devVisit.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx scripts/seed.ts",
    "db:reset": "tsx scripts/reset-db.ts",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.2",
    "@axe-core/playwright": "^4.10.1",
    "aws4fetch": "^1.0.20",
    "axe-core": "^4.10.2",
    "bullmq": "^5.34.5",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "lucide-react": "^1.18.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-auth": "5.0.0-beta.31",
    "playwright": "^1.49.1",
    "pngjs": "^7.0.0",
    "postgres": "^3.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    },
    "ignoredBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
