{
  "name": "web-access",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "dev:api": "pnpm --filter @web-access/api dev",
    "dev:worker": "pnpm --filter @web-access/worker dev",
    "db:push": "pnpm --filter @web-access/api db:push",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
